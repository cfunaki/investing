# Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git - it contains secrets!

# =============================================================================
# Database (Supabase)
# =============================================================================
# Get from Supabase Dashboard > Settings > Database > Connection string > URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres

# =============================================================================
# Gmail API (for email polling - optional initially)
# =============================================================================
# Path to OAuth credentials JSON file (downloaded from Google Cloud Console)
GMAIL_CREDENTIALS_PATH=data/sessions/gmail_credentials.json
# Path where OAuth token will be stored after first authentication
GMAIL_TOKEN_PATH=data/sessions/gmail_token.json
# How often to poll for new emails (seconds)
EMAIL_POLL_INTERVAL_SECONDS=180

# =============================================================================
# Robinhood
# =============================================================================
RH_USERNAME=your_robinhood_email
RH_PASSWORD=your_robinhood_password
# Optional: TOTP secret for 2FA (base32 encoded)
# Get this from your authenticator app setup
RH_TOTP_SECRET=

# =============================================================================
# Telegram
# =============================================================================
# Get from @BotFather after creating your bot
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# Your Telegram user ID (get from @userinfobot)
# Comma-separated list of allowed user IDs
TELEGRAM_ALLOWED_USERS=123456789
# Optional: Default chat ID for notifications
TELEGRAM_CHAT_ID=123456789

# =============================================================================
# Bravos Research credentials
# =============================================================================
BRAVOS_BASE_URL=https://bravosresearch.com
BRAVOS_USERNAME=your_bravos_email
BRAVOS_PASSWORD=your_bravos_password

# =============================================================================
# Browser Worker
# =============================================================================
# Local development
BROWSER_WORKER_URL=http://localhost:8001
# Production (Cloud Run URL)
# BROWSER_WORKER_URL=https://investing-browser-worker-xxxxx.run.app
BROWSER_WORKER_TIMEOUT=120

# =============================================================================
# Safety Controls
# =============================================================================
# IMPORTANT: Start with DRY_RUN=true until you're confident the system works!
DRY_RUN=true
# Maximum dollar amount for any single trade
MAX_TRADE_NOTIONAL=500.0
# Maximum portfolio change as fraction (0.05 = 5%)
MAX_PORTFOLIO_CHANGE_PCT=0.05
# Only trade during market hours
MARKET_HOURS_ONLY=true

# =============================================================================
# Approval Workflow
# =============================================================================
# How long approval requests are valid (minutes)
APPROVAL_EXPIRY_MINUTES=10

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Environment
# =============================================================================
# development, staging, or production
ENVIRONMENT=development
