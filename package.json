{
  "name": "bravos-trade-sync",
  "version": "1.0.0",
  "description": "Scrape Bravos Research trading ideas and reconcile with Robinhood holdings",
  "type": "module",
  "scripts": {
    "init-session": "npx tsx scripts/init-session.ts",
    "scrape": "npx tsx scripts/scrape-ideas.ts",
    "scrape-active": "npx tsx scripts/scrape-active-trades.ts",
    "reconcile": "python scripts/run-reconcile.py",
    "report": "python -m src.reporting.markdown_report"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "playwright": "1.41.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "4.7.0",
    "typescript": "^5.3.0"
  }
}
